{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stac-extensions.github.io/embeddings/v1.0.0/schema.json#",
  "title": "Embedding Extension",
  "description": "STAC Embedding Extension for STAC Items and STAC Collections.",
  "oneOf": [
    {
      "title": "Embedding extension on STAC Items",
      "allOf": [
        {
          "$ref": "https://schemas.stacspec.org/v1.0.0/item-spec/json-schema/item.json"
        },
        {
          "$ref": "#/definitions/stac_extensions"
        },
        {
          "type": "object",
          "required": [
            "type",
            "properties"
          ],
          "properties": {
            "type": {
              "const": "Feature"
            },
            "properties": {
              "$ref": "#/definitions/item_properties_fields"
            },
            "assets": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/asset_fields"
              }
            }
          }
        }
      ]
    },
    {
      "title": "Embedding extension on STAC Collections",
      "allOf": [
        {
          "$ref": "https://schemas.stacspec.org/v1.0.0/collection-spec/json-schema/collection.json"
        },
        {
          "$ref": "#/definitions/stac_extensions"
        },
        {
          "type": "object",
          "required": [
            "type",
            "emb:version",
            "emb:type",
            "emb:dimensions",
            "emb:dtype",
            "links"
          ],
          "properties": {
            "type": {
              "const": "Collection"
            },
            "links": {
              "type": "array",
              "allOf": [
                {
                  "contains": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/stac_link_object"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "rel": {
                            "const": "emb:model"
                          }
                        },
                        "required": [
                          "rel"
                        ]
                      }
                    ]
                  }
                },
                {
                  "contains": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/stac_link_object"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "rel": {
                            "const": "emb:source-data"
                          }
                        },
                        "required": [
                          "rel"
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "assets": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/asset_fields"
              }
            },
            "item_assets": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/asset_fields"
              }
            },
            "summaries": {
              "$ref": "#/definitions/summaries_fields"
            }
          },
          "allOf": [
            {
              "$ref": "#/definitions/collection_fields"
            }
          ]
        }
      ]
    }
  ],
  "definitions": {
    "stac_extensions": {
      "type": "object",
      "required": [
        "stac_extensions"
      ],
      "properties": {
        "stac_extensions": {
          "type": "array",
          "contains": {
            "const": "https://stac-extensions.github.io/embeddings/v1.0.0/schema.json"
          }
        }
      }
    },
    "stac_link_object": {
      "$ref": "https://schemas.stacspec.org/v1.0.0/item-spec/json-schema/item.json#/definitions/link"
    },
    "processing_expression": {
      "description": "Processing expression. SHOULD follow the STAC MLM processing expression format.",
      "oneOf": [
        {
          "type": "object"
        },
        {
          "type": "string"
        }
      ]
    },
    "patch_layout": {
      "type": "object",
      "required": [
        "layout_type"
      ],
      "properties": {
        "layout_type": {
          "type": "string",
          "enum": [
            "regular_grid",
            "variable_grid",
            "named_grid"
          ]
        },
        "patch_size": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "minItems": 2,
              "maxItems": 2
            }
          ]
        },
        "stride": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "minItems": 2,
              "maxItems": 2
            }
          ]
        },
        "grid_id": {
          "type": "string"
        },
        "grid_definition": {
          "$ref": "#/definitions/stac_link_object"
        },
        "patch_geometries": {
          "$ref": "#/definitions/stac_link_object"
        }
      },
      "patternProperties": {
        "^(?!emb:)": {}
      },
      "additionalProperties": false
    },
    "quantization": {
      "type": "object",
      "required": [
        "method",
        "original_dtype"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "original_dtype": {
          "type": "string"
        },
        "scale": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          ]
        },
        "offset": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "asset": {
          "$ref": "#/definitions/stac_link_object"
        }
      },
      "additionalProperties": false
    },
    "collection_fields": {
      "type": "object",
      "properties": {
        "emb:version": {
          "type": "string"
        },
        "emb:type": {
          "type": "string",
          "enum": [
            "pixel",
            "patch"
          ]
        },
        "emb:dimensions": {
          "type": "integer",
          "minimum": 1
        },
        "emb:dtype": {
          "type": "string"
        },
        "emb:shape": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1
        },
        "emb:spatial_resolution": {
          "type": "number"
        },
        "emb:patch_layout": {
          "$ref": "#/definitions/patch_layout"
        },
        "emb:temporal_resolution": {
          "type": "string"
        },
        "emb:fit_for_use": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emb:spatial_coverage": {
          "type": "string"
        },
        "emb:uncertainty": {
          "$ref": "#/definitions/uncertainty"
        }
      },
      "patternProperties": {
        "^(?!emb:)": {}
      },
      "additionalProperties": false
    },
    "item_properties_fields": {
      "type": "object",
      "properties": {
        "emb:runtime_parameters": {
          "type": "object"
        },
        "emb:inference_datetime": {
          "type": "string",
          "format": "date-time"
        },
        "emb:source_data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/stac_link_object"
          }
        },
        "emb:source_data_hash": {
          "type": "string"
        },
        "emb:processing_baseline": {
          "type": "string"
        },
        "emb:preprocessing": {
          "$ref": "#/definitions/processing_expression"
        },
        "emb:postprocessing": {
          "$ref": "#/definitions/processing_expression"
        },
        "emb:fit_for_use": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emb:spatial_coverage": {
          "type": "string"
        },
        "emb:uncertainty": {
          "$ref": "#/definitions/uncertainty"
        }
      },
      "patternProperties": {
        "^(?!emb:)": {}
      },
      "additionalProperties": false
    },
    "asset_fields": {
      "type": "object",
      "properties": {
        "emb:quantization": {
          "$ref": "#/definitions/quantization"
        },
        "emb:crs": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^(?!emb:)": {}
      },
      "additionalProperties": false
    },
    "summaries_fields": {
      "type": "object",
      "properties": {
        "emb:type": {},
        "emb:dimensions": {},
        "emb:dtype": {},
        "emb:shape": {},
        "emb:spatial_resolution": {},
        "emb:temporal_resolution": {},
        "emb:fit_for_use": {},
        "emb:spatial_coverage": {},
        "emb:uncertainty": {}
      },
      "patternProperties": {
        "^(?!emb:)": {}
      },
      "additionalProperties": false
    }
  }
}
